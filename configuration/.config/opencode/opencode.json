
{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "plugin": ["opencode-gemini-auth@latest"],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "deny",
      "grep *": "allow"
    },
    "webfetch": "allow"
  }
}
