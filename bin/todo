#!/usr/bin/env python3
import os
import sys
import datetime
import argparse

import subprocess

# Configuration for input parsing
INPUT_DESC_PREFIX = "--"
INPUT_SUB_PREFIX = "-"

# Configuration for output formatting
OUT_TODO = "- [ ] "
OUT_NOTE = "    - "
OUT_SUBTODO = "    - [ ] "

# Target marker in the file (if found, insert after this line)
TODO_MARKER = "%%insert_todos%%"

def select_file_with_fzf():
    notes_dir = os.getenv("NOTES_DIR")
    if not notes_dir:
        print("Error: NOTES_DIR environment variable is not set.", file=sys.stderr)
        sys.exit(1)
    
    try:
        # Use fd to get list of files, then pipe to sort, then to fzf
        # --absolute-path ensures that absolute paths are returned for the previewer
        fd_cmd = ["fd", "--type", "f", "--extension", "md", "--absolute-path", ".", notes_dir]
        sort_cmd = ["sort"]
        # --no-sort tells fzf not to re-sort the results alphabetically or by relevance
        fzf_cmd = ["fzf", "--prompt=Select file: ", "--no-sort"]
        
        p1 = subprocess.Popen(fd_cmd, stdout=subprocess.PIPE)
        p2 = subprocess.Popen(sort_cmd, stdin=p1.stdout, stdout=subprocess.PIPE)
        p1.stdout.close()
        p3 = subprocess.Popen(fzf_cmd, stdin=p2.stdout, stdout=subprocess.PIPE)
        p2.stdout.close()
        
        stdout, _ = p3.communicate()
        if p3.returncode == 0:
            return stdout.decode().strip()
        else:
            print("Selection cancelled.", file=sys.stderr)
            sys.exit(0)
    except FileNotFoundError:
        print("Error: fzf or find not found in PATH.", file=sys.stderr)
        sys.exit(1)

def parse_date(date_str):
    date_str = date_str.lower().strip()
    today = datetime.date.today()
    
    if date_str == "today":
        return today
    if date_str == "tomorrow":
        return today + datetime.timedelta(days=1)
    if date_str == "yesterday":
        return today - datetime.timedelta(days=1)
    
    weekdays = {
        'monday': 0, 'mon': 0,
        'tuesday': 1, 'tue': 1,
        'wednesday': 2, 'wed': 2,
        'thursday': 3, 'thu': 3,
        'friday': 4, 'fri': 4,
        'saturday': 5, 'sat': 5,
        'sunday': 6, 'sun': 6
    }
    
    # Handle "next [weekday]"
    is_next = False
    if date_str.startswith("next "):
        is_next = True
        date_str = date_str[5:].strip()
        
    if date_str in weekdays:
        target_wd = weekdays[date_str]
        days_ahead = (target_wd - today.weekday()) % 7
        # If it's Monday and I say "Monday", days_ahead is 0.
        # If I say "next Monday", I mean in 7 days.
        if is_next:
            days_ahead += 7
        elif days_ahead == 0:
            # Optional: if it's today, maybe you want next week? 
            # Usually, "Monday" on a Monday means "today".
            pass
        return today + datetime.timedelta(days=days_ahead)
        
    # Fallback to standard format
    return datetime.datetime.strptime(date_str, "%Y-%m-%d").date()

def main():
    parser = argparse.ArgumentParser(description="Add a todo task to the daily journal.")
    parser.add_argument("-t", "--today", action="store_true", help="Set due date and file to today.")
    parser.add_argument("-T", "--tomorrow", action="store_true", help="Set due date and file to tomorrow.")
    parser.add_argument("-n", "--next", type=int, help="Set due date to N days from today.")
    parser.add_argument("-d", "--date", type=str, help="Set due date to a specific YYYY-MM-DD or natural language date.")
    parser.add_argument("-f", "--file", nargs="?", const="SELECT_WITH_FZF", help="Target markdown file. If no file path is given, use fzf in $NOTES_DIR.")
    parser.add_argument("task", nargs="*", help="The task content. If empty, reads from stdin.")

    args = parser.parse_args()

    # Determine date (precedence: -d > -n > -T > -t)
    target_date = datetime.date.today()
    date_flag_used = False

    if args.date:
        try:
            target_date = parse_date(args.date)
            date_flag_used = True
        except ValueError:
            print(f"Error: Invalid date format or keyword '{args.date}'. Use YYYY-MM-DD or words like 'monday'.", file=sys.stderr)
            sys.exit(1)
    elif args.next is not None:
        target_date += datetime.timedelta(days=args.next)
        date_flag_used = True
    elif args.tomorrow:
        target_date += datetime.timedelta(days=1)
        date_flag_used = True
    elif args.today:
        # target_date is already today, but we set flag to add the suffix
        date_flag_used = True

    # Format dates
    date_str = target_date.strftime("%Y-%m-%d")
    due_suffix = f" 📅 {date_str}" if date_flag_used else ""
    # Determine target file
    if args.file == "SELECT_WITH_FZF":
        journal_file = select_file_with_fzf()
    elif args.file:
        journal_file = args.file
    else:
        # Default journal logic
        journal_daily_path = os.getenv("JOURNAL_DAILY_PATH")
        if not journal_daily_path:
            print("Error: JOURNAL_DAILY_PATH environment variable is not set.", file=sys.stderr)
            sys.exit(1)
        journal_file = os.path.join(journal_daily_path, f"{date_str}.md")

    # Ensure the target file's directory exists
    os.makedirs(os.path.dirname(os.path.abspath(journal_file)), exist_ok=True)


    # Get task input
    if args.task:
        # Join arguments into a single string
        input_text = " ".join(args.task)
    else:
        # Read from stdin with line editing support
        if sys.stdin.isatty():
            import readline
            print("Enter todo (Ctrl+D to finish, Ctrl+C to cancel):")
            lines = []
            while True:
                try:
                    # The first line has a different prompt
                    prompt = "Todo: " if not lines else "      "
                    line = input(prompt)
                    lines.append(line)
                except EOFError:
                    print()  # Move to new line after Ctrl+D
                    break
                except KeyboardInterrupt:
                    print("\nCancelled.")
                    sys.exit(0)
            input_text = "\n".join(lines).strip()
        else:
            # Non-interactive (piped) input
            input_text = sys.stdin.read().strip()

    if not input_text:
        print("Error: No task content provided.", file=sys.stderr)
        sys.exit(1)

    # Prepare output lines
    lines = input_text.splitlines()
    output_lines = []
    
    for line in lines:
        stripped = line.strip()
        if not stripped:
            continue
            
        # Determine task type based on prefixes
        is_desc = stripped.startswith(INPUT_DESC_PREFIX)
        # Note: we check desc first because it's longer than sub
        is_sub = stripped.startswith(INPUT_SUB_PREFIX) and not is_desc
        
        # If no task exists yet, everything is a main task
        if not output_lines:
            is_desc = is_sub = False

        if is_desc:
            # Description (Note) of the previous task
            content = stripped[len(INPUT_DESC_PREFIX):].strip()
            output_lines.append(f"{OUT_NOTE}{content}")
        elif is_sub:
            # Sub-todo of the previous task
            content = stripped[len(INPUT_SUB_PREFIX):].strip()
            output_lines.append(f"{OUT_SUBTODO}{content}")
        else:
            # New top-level task
            task_line = f"{OUT_TODO}{stripped}"
            # Append due date if a date flag was used and not already present
            if due_suffix and "📅" not in task_line:
                task_line += due_suffix
            output_lines.append(task_line)

    # Write to file
    try:
        content_to_write = "\n".join(output_lines) + "\n"
        
        if os.path.exists(journal_file) and os.path.getsize(journal_file) > 0:
            with open(journal_file, "r") as f:
                lines = f.readlines()
            
            # Find the marker
            marker_index = -1
            for i, line in enumerate(lines):
                if TODO_MARKER in line:
                    marker_index = i
                    break
            
            if marker_index != -1:
                # Insert after marker
                lines.insert(marker_index + 1, content_to_write)
                with open(journal_file, "w") as f:
                    f.writelines(lines)
            else:
                # Append to end, handle newline
                needs_newline = not lines[-1].endswith("\n")
                with open(journal_file, "a") as f:
                    if needs_newline:
                        f.write("\n")
                    f.write(content_to_write)
        else:
            # New file
            with open(journal_file, "w") as f:
                f.write(content_to_write)
            
        print(f"Added todo to {journal_file}")
    except Exception as e:
        print(f"Error writing to file: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
